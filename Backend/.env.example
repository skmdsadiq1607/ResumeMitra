# ===================================================
# AI Resume Grader - Backend Environment Variables
# ===================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
# Local: mongodb://localhost:27017/ai_resume_grader
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/ai_resume_grader
MONGODB_URI=mongodb://localhost:27017/ai_resume_grader

# --- JWT ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# --- Google Gemini AI ---
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- File Upload ---
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=./uploads

# --- CORS ---
CLIENT_URL=http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
